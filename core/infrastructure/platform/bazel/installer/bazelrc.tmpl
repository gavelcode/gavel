# --- Gavel (generated by `gavel init`) ---
{{- if .Go }}

# --- Go ---
build:gavel --aspects={{ .Prefix }}go_golangci_lint_submission_aspect
build:gavel --output_groups=gavel_submissions
build:gavel-go-archtest --aspects={{ .Prefix }}go_archtest_submission_aspect
build:gavel-go-archtest --output_groups=gavel_submissions
{{- end }}
{{- if .Java }}

# --- Java ---
build:gavel-java-pmd --aspects={{ .Prefix }}java_pmd_submission_aspect
build:gavel-java-pmd --output_groups=gavel_submissions
build:gavel-java-cpd --aspects={{ .Prefix }}java_cpd_submission_aspect
build:gavel-java-cpd --output_groups=gavel_submissions
build:gavel-java-spotbugs --aspects={{ .Prefix }}java_spotbugs_submission_aspect
build:gavel-java-spotbugs --output_groups=gavel_submissions
build:gavel-java-error-prone --aspects={{ .Prefix }}java_error_prone_submission_aspect
build:gavel-java-error-prone --output_groups=gavel_submissions
build:gavel-java-archtest --aspects={{ .Prefix }}java_archtest_submission_aspect
build:gavel-java-archtest --output_groups=gavel_submissions
{{- end }}
{{- if .Python }}

# --- Python ---
build:gavel-python-pycompile --aspects={{ .Prefix }}python_pycompile_submission_aspect
build:gavel-python-pycompile --output_groups=gavel_submissions
build:gavel-python-ruff --aspects={{ .Prefix }}python_ruff_submission_aspect
build:gavel-python-ruff --output_groups=gavel_submissions
build:gavel-python-bandit --aspects={{ .Prefix }}python_bandit_submission_aspect
build:gavel-python-bandit --output_groups=gavel_submissions
build:gavel-python-archtest --aspects={{ .Prefix }}python_archtest_submission_aspect
build:gavel-python-archtest --output_groups=gavel_submissions
{{- end }}
{{- if .TypeScript }}

# --- TypeScript ---
build:gavel-typescript --aspects={{ .Prefix }}typescript_eslint_submission_aspect
build:gavel-typescript --output_groups=gavel_submissions
build:gavel-typescript-archtest --aspects={{ .Prefix }}typescript_archtest_submission_aspect
build:gavel-typescript-archtest --output_groups=gavel_submissions
{{- end }}
{{- if .Rust }}

# --- Rust ---
build:gavel-rust-clippy --aspects={{ .Prefix }}rust_clippy_submission_aspect
build:gavel-rust-clippy --output_groups=gavel_submissions
build:gavel-rust-clippy --@rules_rust//rust/settings:capture_clippy_output=True
build:gavel-rust-clippy --@rules_rust//rust/settings:clippy_output_diagnostics=True
build:gavel-rust-archtest --aspects={{ .Prefix }}rust_archtest_submission_aspect
build:gavel-rust-archtest --output_groups=gavel_submissions
{{- end }}
