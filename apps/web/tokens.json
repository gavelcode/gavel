    "duration.fast": {
      "$value": "100ms",
      "$type": "duration"
    },
    "duration.normal": {
      "$value": "200ms",
      "$type": "duration"
    },
    "duration.slow": {
      "$value": "350ms",
      "$type": "duration"
    },
    "ease.out": {
      "$value": "cubic-bezier(0.16, 1, 0.3, 1)",
